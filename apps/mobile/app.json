{
  "expo": {
    "name": "Stipulate",
    "slug": "stipulate",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "stipulate",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.stipulate.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan receipts to extract merchant details for card routing.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B"
      },
      "package": "io.stipulate.app",
      "versionCode": 1,
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
