{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000/v1",
        "EXPO_PUBLIC_API_KEY": "stip_dev_local_key_change_in_production"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.staging.stipulate.io/v1",
        "EXPO_PUBLIC_API_KEY": ""
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.stipulate.io/v1",
        "EXPO_PUBLIC_API_KEY": ""
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "ops@stipulate.io",
        "ascAppId": "stipulate-mobile"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
  }
}
