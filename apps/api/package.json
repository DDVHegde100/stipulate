{
  "name": "@stipulate/api",
  "version": "0.1.0",
  "private": true,
  "description": "Stipulate card benefit intelligence platform — HTTP API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed-cards.ts",
    "db:seed-valuations": "tsx scripts/seed-valuations.ts",
    "schedule:reparse": "tsx scripts/schedule-reparse.ts",
    "schedule:digest": "tsx scripts/schedule-digest.ts",
    "schedule:ingestion": "tsx scripts/schedule-ingestion.ts",
    "worker:supervisor": "tsx scripts/worker-supervisor.ts",
    "benchmark:route": "tsx scripts/benchmark-route.ts",
    "webhooks:deliver": "tsx scripts/webhook-worker.ts",
    "ingestion:worker": "tsx scripts/ingestion-worker.ts",
    "ingestion:sqs-worker": "tsx scripts/sqs-ingestion-worker.ts",
    "db:seed-benefits": "tsx scripts/seed-benefits-from-fixtures.ts",
    "smoke": "tsx scripts/smoke-api.ts",
    "batch:parse": "tsx scripts/batch-parse-catalog.ts",
    "reconcile:stripe": "tsx scripts/reconcile-stripe-usage.ts",
    "purge:deletions": "tsx scripts/purge-scheduled-deletions.ts",
    "verify:benefit-coverage": "tsx scripts/verify-benefit-coverage.ts",
    "bootstrap:org": "tsx scripts/bootstrap-org.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/client-sqs": "^3.758.0",
    "@hono/node-server": "^1.14.1",
    "@stipulate/mcc": "workspace:*",
    "@stipulate/parser": "workspace:*",
    "@stipulate/routing": "workspace:*",
    "@stipulate/schema": "workspace:*",
    "hono": "^4.7.5",
    "ioredis": "^5.6.0",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "thread-stream": "^3.2.0",
    "zod": "^3.24.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
