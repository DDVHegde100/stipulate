{
  "name": "@stipulate/api",
  "version": "0.1.0",
  "private": true,
  "description": "Stipulate card benefit intelligence platform — HTTP API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed-cards.ts",
    "db:seed-valuations": "tsx scripts/seed-valuations.ts",
    "schedule:reparse": "tsx scripts/schedule-reparse.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@stipulate/parser": "workspace:*",
    "@stipulate/schema": "workspace:*",
    "hono": "^4.7.5",
    "ioredis": "^5.6.0",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "thread-stream": "^4.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
