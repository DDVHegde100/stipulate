# =============================================================================
# Stipulate Environment Configuration
# Copy to .env and fill in values for local development
# =============================================================================

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=debug

# --- API Server (@stipulate/api) ---
PORT=3000
API_VERSION=v1
API_KEY=stip_dev_local_key_change_in_production
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql://stipulate:stipulate_dev@localhost:5432/stipulate
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# --- Redis (matches docker-compose.yml) ---
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=stipulate:

# --- AWS / LocalStack (local dev) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BENEFIT_PDF_BUCKET=stipulate-benefit-pdfs
S3_PARSER_ARTIFACTS_BUCKET=stipulate-parser-artifacts
SQS_PARSER_JOBS_QUEUE=http://localhost:4566/000000000000/stipulate-parser-jobs
SNS_BENEFIT_CHANGES_TOPIC=arn:aws:sns:us-east-1:000000000000:stipulate-benefit-changes

# --- LLM Parser (@stipulate/parser) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
PARSER_CONFIDENCE_THRESHOLD=0.85
PARSER_MAX_RETRIES=3

# --- Web App (@stipulate/web) ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=generate-a-random-32-char-secret-here

# --- Mobile App (@stipulate/mobile) ---
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- Billing (Stripe — production only) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_SAAS=price_...
STRIPE_PRICE_ID_CONSUMER=price_...

# --- Observability ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- Feature Flags ---
FEATURE_PROXY_PAY=false
FEATURE_RECEIPT_OCR=false
FEATURE_BENEFIT_WEBHOOKS=true
