# Stipulate production environment template
# Copy values into your secret manager (Railway, Fly.io, AWS SSM, etc.)

NODE_ENV=production
LOG_LEVEL=info

# API
PORT=3000
API_VERSION=v1
API_HOST=0.0.0.0
CORS_ORIGINS=https://stipulate.io,https://www.stipulate.io

# Database (SSL required in production)
DATABASE_URL=postgresql://user:password@host:5432/stipulate?sslmode=require
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=true

# Redis
REDIS_URL=rediss://user:password@host:6379
REDIS_PREFIX=stipulate:

# AWS
AWS_REGION=us-east-1
S3_BENEFIT_PDF_BUCKET=stipulate-benefit-pdfs-prod
S3_PARSER_ARTIFACTS_BUCKET=stipulate-parser-artifacts-prod
SQS_PARSER_JOBS_QUEUE=https://sqs.us-east-1.amazonaws.com/ACCOUNT/stipulate-parser-jobs
SNS_BENEFIT_CHANGES_TOPIC=arn:aws:sns:us-east-1:ACCOUNT:stipulate-benefit-changes

# LLM parser
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PARSER_CONFIDENCE_THRESHOLD=0.85

# Web
NEXT_PUBLIC_APP_URL=https://stipulate.io
NEXT_PUBLIC_API_URL=https://api.stipulate.io/v1
NEXTAUTH_URL=https://stipulate.io
NEXTAUTH_SECRET=

# Billing
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_ID_SAAS=price_
STRIPE_PRICE_ID_CONSUMER=price_

# Observability
SENTRY_DSN=
POSTHOG_API_KEY=

# Admin
ADMIN_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@stipulate.io

# Plaid (bank linking — sandbox)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
FEATURE_RECEIPT_OCR=false
FEATURE_BENEFIT_WEBHOOKS=true
