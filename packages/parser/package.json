{
  "name": "@stipulate/parser",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-powered benefit guide extraction and normalization pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest run src/eval"
  },
  "dependencies": {
    "@stipulate/schema": "workspace:*",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
