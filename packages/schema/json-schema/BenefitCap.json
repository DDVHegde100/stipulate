{
  "$ref": "https://stipulate.io/schemas/v1/BenefitCap/definitions/BenefitCap",
  "definitions": {
    "BenefitCap": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "period": {
          "type": "string",
          "enum": [
            "annual",
            "quarterly",
            "monthly",
            "per_transaction",
            "lifetime"
          ]
        },
        "limit": {
          "type": "object",
          "properties": {
            "amountMinor": {
              "type": "integer"
            },
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "default": "USD"
            }
          },
          "required": [
            "amountMinor"
          ],
          "additionalProperties": false
        },
        "resetPolicy": {
          "type": "string",
          "enum": [
            "calendar_year",
            "statement_cycle",
            "rolling",
            "none"
          ],
          "default": "calendar_year"
        },
        "description": {
          "type": "string"
        },
        "carryForward": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "id",
        "period",
        "limit"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}