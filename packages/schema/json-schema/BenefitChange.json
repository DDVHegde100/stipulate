{
  "$ref": "https://stipulate.io/schemas/v1/BenefitChange/definitions/BenefitChange",
  "definitions": {
    "BenefitChange": {
      "type": "object",
      "properties": {
        "card_id": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "dining",
            "groceries",
            "travel",
            "airfare",
            "hotels",
            "transit",
            "gas",
            "streaming",
            "entertainment",
            "retail",
            "healthcare",
            "utilities",
            "insurance",
            "education",
            "charity",
            "government",
            "cash_equivalent",
            "other"
          ]
        },
        "old_value": {},
        "new_value": {},
        "detected_at": {
          "type": "string",
          "format": "date-time"
        },
        "severity": {
          "type": "string",
          "enum": [
            "breaking",
            "material",
            "minor"
          ],
          "default": "material"
        }
      },
      "required": [
        "card_id",
        "field",
        "detected_at"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}