{
  "$ref": "https://stipulate.io/schemas/v1/MerchantEnrichment/definitions/MerchantEnrichment",
  "definitions": {
    "MerchantEnrichment": {
      "type": "object",
      "properties": {
        "merchantName": {
          "type": "string",
          "minLength": 1
        },
        "normalizedName": {
          "type": "string",
          "minLength": 1
        },
        "mcc": {
          "type": "string",
          "pattern": "^\\d{4}$"
        },
        "mccDescription": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "dining",
            "groceries",
            "travel",
            "airfare",
            "hotels",
            "transit",
            "gas",
            "streaming",
            "entertainment",
            "retail",
            "healthcare",
            "utilities",
            "insurance",
            "education",
            "charity",
            "government",
            "cash_equivalent",
            "other"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source": {
          "type": "string",
          "enum": [
            "user",
            "mcc_db",
            "llm",
            "override",
            "issuer",
            "plaid",
            "unknown"
          ]
        },
        "mccCandidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mcc": {
                "type": "string",
                "pattern": "^\\d{4}$"
              },
              "description": {
                "type": "string"
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "mcc",
              "score"
            ],
            "additionalProperties": false
          }
        },
        "overrideApplied": {
          "type": "string"
        }
      },
      "required": [
        "merchantName",
        "normalizedName",
        "confidence",
        "source"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}