{
  "$ref": "https://stipulate.io/schemas/v1/RouteRequest/definitions/RouteRequest",
  "definitions": {
    "RouteRequest": {
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "merchantName": {
          "type": "string",
          "minLength": 1
        },
        "mcc": {
          "type": "string",
          "pattern": "^\\d{4}$"
        },
        "amount": {
          "type": "object",
          "properties": {
            "amountMinor": {
              "type": "integer"
            },
            "currency": {
              "type": "string",
              "minLength": 3,
              "maxLength": 3,
              "pattern": "^[A-Z]{3}$",
              "default": "USD"
            }
          },
          "required": [
            "amountMinor"
          ],
          "additionalProperties": false
        },
        "userCardIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "channel": {
          "type": "string",
          "enum": [
            "in_store",
            "online",
            "mobile_wallet",
            "contactless",
            "mail_order",
            "unknown"
          ],
          "default": "unknown"
        },
        "isInternational": {
          "type": "boolean",
          "default": false
        },
        "merchantEnrichment": {
          "type": "object",
          "properties": {
            "merchantName": {
              "type": "string",
              "minLength": 1
            },
            "normalizedName": {
              "type": "string",
              "minLength": 1
            },
            "mcc": {
              "type": "string",
              "pattern": "^\\d{4}$"
            },
            "mccDescription": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "enum": [
                "dining",
                "groceries",
                "travel",
                "airfare",
                "hotels",
                "transit",
                "gas",
                "streaming",
                "entertainment",
                "retail",
                "healthcare",
                "utilities",
                "insurance",
                "education",
                "charity",
                "government",
                "cash_equivalent",
                "other"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "source": {
              "type": "string",
              "enum": [
                "user",
                "mcc_db",
                "llm",
                "override",
                "issuer",
                "plaid",
                "unknown"
              ]
            },
            "mccCandidates": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "mcc": {
                    "type": "string",
                    "pattern": "^\\d{4}$"
                  },
                  "description": {
                    "type": "string"
                  },
                  "score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  }
                },
                "required": [
                  "mcc",
                  "score"
                ],
                "additionalProperties": false
              }
            },
            "overrideApplied": {
              "type": "string"
            }
          },
          "required": [
            "merchantName",
            "normalizedName",
            "confidence",
            "source"
          ],
          "additionalProperties": false
        },
        "preferences": {
          "type": "object",
          "properties": {
            "optimizeFor": {
              "type": "string",
              "enum": [
                "max_reward",
                "min_fees",
                "balanced"
              ],
              "default": "max_reward"
            },
            "excludeCardIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "optimizeFor": "max_reward",
            "excludeCardIds": []
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "amount",
        "userCardIds"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}