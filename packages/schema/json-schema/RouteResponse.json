{
  "$ref": "https://stipulate.io/schemas/v1/RouteResponse/definitions/RouteResponse",
  "definitions": {
    "RouteResponse": {
      "type": "object",
      "properties": {
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "rankedCards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "cardId": {
                "type": "string",
                "minLength": 1
              },
              "rank": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "score": {
                "type": "number"
              },
              "effectiveMultiplier": {
                "type": "number",
                "minimum": 0
              },
              "estimatedReward": {
                "type": "object",
                "properties": {
                  "amountMinor": {
                    "type": "integer"
                  },
                  "currency": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 3,
                    "pattern": "^[A-Z]{3}$",
                    "default": "USD"
                  }
                },
                "required": [
                  "amountMinor"
                ],
                "additionalProperties": false
              },
              "applicableRuleIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "excludedBy": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "exclusionId": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "exclusionId"
                  ],
                  "additionalProperties": false
                }
              },
              "fees": {
                "type": "object",
                "properties": {
                  "foreignTransactionFee": {
                    "type": "object",
                    "properties": {
                      "amountMinor": {
                        "type": "integer"
                      },
                      "currency": {
                        "type": "string",
                        "minLength": 3,
                        "maxLength": 3,
                        "pattern": "^[A-Z]{3}$",
                        "default": "USD"
                      }
                    },
                    "required": [
                      "amountMinor"
                    ],
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              },
              "reasoning": {
                "type": "string"
              }
            },
            "required": [
              "cardId",
              "rank",
              "score",
              "effectiveMultiplier",
              "estimatedReward",
              "applicableRuleIds"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "merchantEnrichment": {
          "type": "object",
          "properties": {
            "merchantName": {
              "type": "string",
              "minLength": 1
            },
            "normalizedName": {
              "type": "string",
              "minLength": 1
            },
            "mcc": {
              "type": "string",
              "pattern": "^\\d{4}$"
            },
            "mccDescription": {
              "type": "string"
            },
            "category": {
              "type": "string",
              "enum": [
                "dining",
                "groceries",
                "travel",
                "airfare",
                "hotels",
                "transit",
                "gas",
                "streaming",
                "entertainment",
                "retail",
                "healthcare",
                "utilities",
                "insurance",
                "education",
                "charity",
                "government",
                "cash_equivalent",
                "other"
              ]
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "source": {
              "type": "string",
              "enum": [
                "user",
                "mcc_db",
                "llm",
                "override",
                "issuer",
                "plaid",
                "unknown"
              ]
            },
            "mccCandidates": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "mcc": {
                    "type": "string",
                    "pattern": "^\\d{4}$"
                  },
                  "description": {
                    "type": "string"
                  },
                  "score": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  }
                },
                "required": [
                  "mcc",
                  "score"
                ],
                "additionalProperties": false
              }
            },
            "overrideApplied": {
              "type": "string"
            }
          },
          "required": [
            "merchantName",
            "normalizedName",
            "confidence",
            "source"
          ],
          "additionalProperties": false
        },
        "bestCardId": {
          "type": "string",
          "minLength": 1
        },
        "computedAt": {
          "type": "string",
          "format": "date-time"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "requestId",
        "rankedCards",
        "bestCardId",
        "computedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}