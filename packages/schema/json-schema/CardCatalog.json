{
  "$ref": "https://stipulate.io/schemas/v1/CardCatalog/definitions/CardCatalog",
  "definitions": {
    "CardCatalog": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "issuer": {
          "type": "string"
        },
        "cards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "issuer": {
                "type": "string",
                "minLength": 1
              },
              "productName": {
                "type": "string",
                "minLength": 1
              },
              "network": {
                "type": "string",
                "enum": [
                  "visa",
                  "mastercard",
                  "amex",
                  "discover"
                ]
              },
              "annualFee": {
                "type": "object",
                "properties": {
                  "amountMinor": {
                    "type": "integer"
                  },
                  "currency": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 3,
                    "pattern": "^[A-Z]{3}$",
                    "default": "USD"
                  }
                },
                "required": [
                  "amountMinor"
                ],
                "additionalProperties": false
              },
              "foreignTransactionFeeRate": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "benefitRuleIds": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "benefitRules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "cardId": {
                      "type": "string",
                      "minLength": 1
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "description": {
                      "type": "string"
                    },
                    "category": {
                      "type": "string",
                      "enum": [
                        "dining",
                        "groceries",
                        "travel",
                        "airfare",
                        "hotels",
                        "transit",
                        "gas",
                        "streaming",
                        "entertainment",
                        "retail",
                        "healthcare",
                        "utilities",
                        "insurance",
                        "education",
                        "charity",
                        "government",
                        "cash_equivalent",
                        "other"
                      ]
                    },
                    "multiplier": {
                      "type": "number",
                      "minimum": 0
                    },
                    "rewardType": {
                      "type": "string",
                      "enum": [
                        "points",
                        "cashback",
                        "miles"
                      ],
                      "default": "points"
                    },
                    "caps": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "minLength": 1
                          },
                          "period": {
                            "type": "string",
                            "enum": [
                              "annual",
                              "quarterly",
                              "monthly",
                              "per_transaction",
                              "lifetime"
                            ]
                          },
                          "limit": {
                            "type": "object",
                            "properties": {
                              "amountMinor": {
                                "type": "integer"
                              },
                              "currency": {
                                "type": "string",
                                "minLength": 3,
                                "maxLength": 3,
                                "pattern": "^[A-Z]{3}$",
                                "default": "USD"
                              }
                            },
                            "required": [
                              "amountMinor"
                            ],
                            "additionalProperties": false
                          },
                          "resetPolicy": {
                            "type": "string",
                            "enum": [
                              "calendar_year",
                              "statement_cycle",
                              "rolling",
                              "none"
                            ],
                            "default": "calendar_year"
                          },
                          "description": {
                            "type": "string"
                          },
                          "carryForward": {
                            "type": "boolean",
                            "default": false
                          }
                        },
                        "required": [
                          "id",
                          "period",
                          "limit"
                        ],
                        "additionalProperties": false
                      },
                      "default": []
                    },
                    "exclusions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "minLength": 1
                          },
                          "type": {
                            "type": "string",
                            "enum": [
                              "merchant",
                              "mcc",
                              "category",
                              "channel",
                              "geography"
                            ]
                          },
                          "matcher": {
                            "type": "string",
                            "minLength": 1
                          },
                          "isRegex": {
                            "type": "boolean",
                            "default": false
                          },
                          "reason": {
                            "type": "string"
                          },
                          "sourceNote": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "type",
                          "matcher"
                        ],
                        "additionalProperties": false
                      },
                      "default": []
                    },
                    "minSpend": {
                      "type": "object",
                      "properties": {
                        "amountMinor": {
                          "type": "integer"
                        },
                        "currency": {
                          "type": "string",
                          "minLength": 3,
                          "maxLength": 3,
                          "pattern": "^[A-Z]{3}$",
                          "default": "USD"
                        }
                      },
                      "required": [
                        "amountMinor"
                      ],
                      "additionalProperties": false
                    },
                    "effectiveFrom": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "effectiveTo": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "requiresActivation": {
                      "type": "boolean",
                      "default": false
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": {}
                    }
                  },
                  "required": [
                    "id",
                    "cardId",
                    "name",
                    "category",
                    "multiplier"
                  ],
                  "additionalProperties": false
                }
              },
              "benefitGuideUrl": {
                "type": "string",
                "format": "uri"
              },
              "isActive": {
                "type": "boolean",
                "default": true
              },
              "metadata": {
                "type": "object",
                "additionalProperties": {}
              }
            },
            "required": [
              "id",
              "issuer",
              "productName",
              "network"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "version",
        "generatedAt",
        "cards"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}